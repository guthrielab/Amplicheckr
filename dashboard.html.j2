<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">

<style>
body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    background: #f5f5f3;
    color: #1a1a18;
    margin: 0;
    padding: 20px;
}

/* Header */
.report-header {
    margin-bottom: 20px;
}
.report-title {
    font-size: 20px;
    font-weight: 600;
}

/* Summary */
.summary-grid {
    display: flex;
    gap: 10px;
    margin-bottom: 20px;
}

.stat-card {
    background: white;
    border: 1px solid rgba(0,0,0,0.1);
    padding: 10px;
    border-radius: 8px;
    min-width: 120px;
}

.stat-label {
    font-size: 12px;
    color: #666;
}
.stat-value {
    font-size: 20px;
    font-weight: 600;
}

/* Set container */
.primer-set {
    background: white;
    border: 1px solid rgba(0,0,0,0.12);
    border-radius: 12px;
    margin-bottom: 12px;
    overflow: hidden;
}

/* Header */
.set-header {
    display: flex;
    justify-content: space-between;
    padding: 10px 14px;
    background: #fafafa;
    cursor: pointer;
}

.set-num {
    font-weight: 600;
}

/* Stats */
.status-ok {
    color: green;
}
.status-err {
    color: #b00020;
}

/* Alignment cards */
.alignment-card {
    border-top: 1px solid #eee;
    padding: 10px 14px;
}

.aln-top {
    display: flex;
    gap: 8px;
    align-items: center;
    margin-bottom: 8px;
}

.primer-name {
    font-family: monospace;
    font-weight: 600;
}

/* Badges */
.type-badge {
    font-size: 11px;
    padding: 2px 6px;
    border-radius: 4px;
    background: #ddd;
}

.type-f { background: #cfe8ff; }
.type-r { background: #d7f7e3; }
.type-p { background: #ffe3b3; }

.risk-badge {
    font-size: 11px;
    padding: 2px 6px;
    border-radius: 4px;
}

.risk-no { background: #e6f4ea; color: #1e6b2f; }
.risk-high { background: #fde7e7; color: #a00000; }

.aln-seq pre {
    margin: 0;
    font-family: monospace;
    font-size: 12px;
    line-height: 1.4;
    white-space: pre;
    background: #f7f7f7;
    padding: 8px;
    border-radius: 6px;
    overflow-x: auto;
}

/* Meta */
.aln-meta {
    margin-top: 6px;
    font-size: 12px;
    color: #555;
}

.aln-matches {
    font-size: 11px;
    color: #777;
    margin-top: 4px;
}

/* Failures */
.failure-banner {
    background: #fff3f3;
    padding: 10px;
    border-bottom: 1px solid #ffd0d0;
}

.failure-label {
    font-weight: 600;
    color: #b00020;
    font-size: 12px;
}

.failure-item {
    font-size: 12px;
    color: #7a1a1a;
}
</style>

</head>

<body>

<div class="report-header">
    <div class="report-title">Primer Alignment Report</div>
</div>

<div class="summary-grid">
    <div class="stat-card">
        <div class="stat-label">Primer Sets</div>
        <div class="stat-value">{{ primer_sets|length }}</div>
    </div>

    <div class="stat-card">
        <div class="stat-label">Total Genomes</div>
        <div class="stat-value">{{ primer_sets[0].total_genomes_parsed }}</div>
    </div>
</div>

{% macro render_primer(p) %}

{% set mismatches = p.visual.count('X') %}

<div class="alignment-card">

    <div class="aln-top">

        <span class="primer-name">{{ p.name }}</span>

        <span class="type-badge type-{{ p.type|lower }}">
            {{ p.type }}
        </span>

        <span class="risk-badge {% if p.primer_rating == 'High Risk' %}risk-high{% else %}risk-no{% endif %}">
            {{ p.primer_rating }}
        </span>

    </div>

    <div class="aln-seq">
<pre>
Query : {{ p.query_alignment }}
        {{ p.visual }}
DB    : {{ p.database_alignment }}
</pre>
    </div>

    <div class="aln-meta">
        Coverage: {{ p.prevalence }}
        {% if mismatches > 0 %}
        | Mismatches: {{ mismatches }}
        {% endif %}
    </div>

    <div class="aln-matches">
        {{ p.matches }}
    </div>

</div>

{% endmacro %}


{% for ps in primer_sets %}

<div class="primer-set">

    <div class="set-header">
        <span class="set-num">{{ ps.name }}</span>

        {% if ps.failures %}
            <span class="status-err">✕ {{ ps.failures|length }} failures</span>
        {% else %}
            <span class="status-ok">✓ Clean</span>
        {% endif %}
    </div>

    {% if ps.failures %}
    <div class="failure-banner">
        <div class="failure-label">Failures</div>
        {% for f in ps.failures %}
            <div class="failure-item">{{ f.id }} — {{ f.message }}</div>
        {% endfor %}
    </div>
    {% endif %}

    {% for primer in ps.primers %}
        {{ render_primer(primer) }}
    {% endfor %}

</div>

{% endfor %}

</body>
</html>