<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">

<style>
body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    background: #f5f5f3;
    color: #1a1a18;
    margin: 0;
    padding: 20px;
}

/* Header */
.report-header {
    margin-bottom: 20px;
}
.report-title {
    font-size: 20px;
    font-weight: 600;
}

/* Summary */
.summary-grid {
    display: flex;
    gap: 10px;
    margin-bottom: 20px;
}

.stat-card {
    background: white;
    border: 1px solid rgba(0,0,0,0.1);
    padding: 10px;
    border-radius: 8px;
    min-width: 120px;
}

.stat-label {
    font-size: 12px;
    color: #666;
}
.stat-value {
    font-size: 20px;
    font-weight: 600;
}

/* Set container */
.primer-set {
    background: white;
    border: 1px solid rgba(0,0,0,0.12);
    border-radius: 12px;
    margin-bottom: 12px;
    overflow: hidden;
}

/* Header */
.set-header {
    display: flex;
    justify-content: space-between;
    padding: 10px 14px;
    background: #fafafa;
    cursor: pointer;
}

.set-num {
    font-weight: 600;
}

/* Stats */
.status-ok {
    color: green;
}
.status-err {
    color: #b00020;
}

/* Alignment cards */
.alignment-card {
    border-top: 1px solid #eee;
    padding: 10px 14px 10px 12px;
    border-left: 4px solid transparent;
}

.alignment-card.type-f {
    border-left-color: #4a9eea;
    background: #f8fbff;
}
.alignment-card.type-r {
    border-left-color: #2fa968;
    background: #f7fcf9;
}
.alignment-card.type-p {
    border-left-color: #d9971f;
    background: #fffaf2;
}

.aln-top {
    display: flex;
    gap: 8px;
    align-items: center;
    margin-bottom: 8px;
}

.primer-name {
    font-family: monospace;
    font-weight: 600;
}

/* Badges */
.type-badge {
    font-size: 11px;
    font-weight: 600;
    padding: 2px 8px;
    border-radius: 4px;
    background: #ddd;
}

.type-f { background: #cfe8ff; color: #17548c; }
.type-r { background: #d7f7e3; color: #196b3f; }
.type-p { background: #ffe3b3; color: #8a5c05; }

.risk-badge {
    font-size: 11px;
    padding: 2px 6px;
    border-radius: 4px;
}

.risk-no { background: #e6f4ea; color: #1e6b2f; }
.risk-high { background: #fde7e7; color: #a00000; }

.aln-seq pre {
    margin: 0;
    font-family: monospace;
    font-size: 12px;
    line-height: 1.4;
    white-space: pre;
    background: #f7f7f7;
    padding: 8px;
    border-radius: 6px;
    overflow-x: auto;
}

/* Meta */
.aln-meta {
    margin-top: 4px;
    font-size: 14px;
    color: #282828;
}
.aln-tm {
    margin-top: 6px;
    font-size: 14px;
    color: #282828;
}
.aln-matches {
    font-size: 11px;
    color: #777;
    margin-top: 4px;
}

/* Failures */
.failure-banner {
    background: #fff3f3;
    padding: 10px;
    border-bottom: 1px solid #ffd0d0;
}

.failure-label {
    font-weight: 600;
    color: #b00020;
    font-size: 12px;
}

.failure-item {
    font-size: 12px;
    color: #7a1a1a;
}

/* No-match warning card (score == -1, i.e. nomatch placeholder) */
.nomatch-card {
    border-top: 1px solid #eee;
    padding: 10px 14px;
    background: #fffaf0;
    display: flex;
    gap: 8px;
    align-items: flex-start;
}

.nomatch-icon {
    font-size: 14px;
    line-height: 1.4;
    color: #a06400;
}

.nomatch-text {
    font-size: 13px;
    color: #6b4e00;
}

/* Segment report */
.segment-report {
    border-top: 1px solid #eee;
    padding: 12px 14px;
    background: #fbfbfa;
}

.segment-stats {
    display: flex;
    gap: 10px;
    margin-bottom: 12px;
}

.segment-stats .stat-card {
    min-width: 0;
    flex: 1;
}

.segment-tables {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
}

.segment-table-block {
    background: white;
    border: 1px solid rgba(0,0,0,0.08);
    border-radius: 8px;
    padding: 8px 10px;
    flex: 1;
    min-width: 160px;
}

.segment-table-title {
    font-size: 11px;
    font-weight: 600;
    color: #555;
    margin-bottom: 6px;
    text-transform: uppercase;
    letter-spacing: 0.02em;
}

table.segment-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 12px;
}

table.segment-table td {
    padding: 3px 4px;
    border-bottom: 1px solid #f0f0f0;
}

table.segment-table td.segment-count {
    text-align: right;
    font-family: monospace;
    color: #333;
}

.segment-table-empty {
    font-size: 12px;
    color: #999;
}
</style>

</head>

<body>

<div class="report-header">
    <div class="report-title">Primer Alignment Report</div>
</div>

<div class="summary-grid">
    <div class="stat-card">
        <div class="stat-label">Primer Sets</div>
        <div class="stat-value">{{ primer_sets|length }}</div>
    </div>

    <div class="stat-card">
        <div class="stat-label">Total Genomes</div>
        <div class="stat-value">{{ primer_sets[0].total_genomes_parsed }}</div>
    </div>
</div>

{% macro segval(v) -%}
{{ v|int if v == v else 0 }}
{%- endmacro %}

{% macro segment_table(title, composition) %}
<div class="segment-table-block">
    <div class="segment-table-title">{{ title }}</div>
    {% if composition %}
    <table class="segment-table">
        {% for seg, count in composition.items() %}
        <tr>
            <td>{{ seg }}</td>
            <td class="segment-count">{{ segval(count) }}</td>
        </tr>
        {% endfor %}
    </table>
    {% else %}
    <div class="segment-table-empty">No data</div>
    {% endif %}
</div>
{% endmacro %}

{% macro render_primer(p, setnum) %}

{% if p.score == -1 %}

{% set type_label = {'f': 'Forward primer', 'r': 'Reverse primer', 'p': 'Probe'}.get(p.type|lower, 'Primer') %}

<div class="nomatch-card">
    <div class="nomatch-icon">&#9888;</div>
    <div class="nomatch-text">
        {{ type_label }} <span class="primer-name">{{ p.id }}</span> has no alignments above threshold score for primer set #{{ setnum }}.
    </div>
</div>

{% else %}

{% set mismatches = p.visual.count('X') %}
{% set type_label = {'f': 'Forward', 'r': 'Reverse', 'p': 'Probe'}.get(p.type|lower, p.type) %}

<div class="alignment-card type-{{ p.type|lower }}">

    <div class="aln-top">

        <span class="primer-name">{{ p.name }}</span>

        <span class="type-badge type-{{ p.type|lower }}">
            {{ type_label }}
        </span>

        <span class="risk-badge {% if p.primer_rating == 'High Risk' %}risk-high{% else %}risk-no{% endif %}">
            {{ p.primer_rating }}
        </span>
        
    </div>

    <div class="aln-seq">
<pre>
Query : {{ p.query_alignment }}
        {{ p.visual }}
DB    : {{ p.database_alignment }}
</pre>
    </div>
    <div class="aln-tm"> Tm = {{ p.melting_temperature }}</div>
    <div class="aln-meta">
        Coverage: {{ p.prevalence }}
        {% if mismatches > 0 %}
        | Mismatches: {{ mismatches }}
        {% endif %}
    </div>

    <div class="aln-matches">
        {{ p.matches }}
    </div>

</div>

{% endif %}

{% endmacro %}


{% for ps in primer_sets %}

{% set setnum = loop.index %}

<div class="primer-set">

    {% if ps.entry is defined and not ps.entry %}

    <div class="set-header">
        <span class="set-num">{{ ps.name }}</span>
        <span class="status-err">✕ No data</span>
    </div>

    <div class="failure-banner">
        <div class="failure-label">No Data</div>
        <div class="failure-item">No sequences were found above the score threshold for {{ ps.name }}.</div>
    </div>

    {% else %}

    <div class="set-header">
        <span class="set-num">{{ ps.name }}</span>

        {% if ps.failures %}
            <span class="status-err">✕ {{ ps.failures|length }} failures</span>
        {% else %}
            <span class="status-ok">✓ Clean</span>
        {% endif %}
    </div>

    {% if ps.failures %}
    <div class="failure-banner">
        <div class="failure-label">Failures</div>
        {% for f in ps.failures %}
            <div class="failure-item">{{ f.id }} — {{ f.message }}</div>
        {% endfor %}
    </div>
    {% endif %}

    <div class="segment-report">
        <div class="segment-stats">
            <div class="stat-card">
                <div class="stat-label">Total Genomes Parsed</div>
                <div class="stat-value">{{ ps.total_genomes_parsed }}</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Raw Genomes Matched</div>
                <div class="stat-value">{{ ps.raw_genomes_matched }}</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Valid Matches</div>
                <div class="stat-value">{{ ps.valid_matches }}</div>
            </div>
        </div>

        <div class="segment-tables">
            {{ segment_table("Genome Segment Composition", ps.genome_segment_composition) }}
            {{ segment_table("Matched Segment Composition", ps.match_segment_composition) }}
            {{ segment_table("Invalidated Match Composition", ps.invalid_match_segment_composition) }}
        </div>
    </div>

    {% for primer in ps.primers %}
        {{ render_primer(primer, setnum) }}
    {% endfor %}

    {% endif %}

</div>

{% endfor %}

</body>
</html>
